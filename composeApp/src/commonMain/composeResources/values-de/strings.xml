    <string name="settings_title">Einstellungen</string>
    <string name="settings_section_series_title">Serientitel</string>
    <string name="settings_section_series_title_desc">Welcher Titel für eine zugeordnete Serie angezeigt wird - greift auf den Datei-/Ordnernamen zurück, wenn der zugeordnete Anbieter diese Sprache nicht hat.</string>
    <string name="settings_section_start_screen">Startbildschirm</string>
    <string name="settings_section_start_screen_desc">Welcher Bibliotheks-Tab beim Start geöffnet wird -- manuelles Wechseln bleibt für den Rest der Sitzung bestehen.</string>
    <string name="settings_section_metadata_provider">Metadatenanbieter</string>
    <string name="settings_section_metadata_provider_desc">Wird für den automatischen Abgleich neuer Serien verwendet. Metadaten korrigieren (auf einem Serienbildschirm) kann für diese eine Suche immer einen anderen Anbieter verwenden.</string>
    <string name="settings_section_reading_mode">Standard-Lesemodus</string>
    <string name="settings_section_reading_mode_desc">Wird für jede Serie verwendet, die du nicht einzeln umgestellt hast — die Reader-Oberfläche hat einen Schnellumschalter, der sich deine Wahl pro Serie merkt.</string>
    <string name="settings_swap_tap_zones_title">Tippbereiche vertauschen</string>
    <string name="settings_swap_tap_zones_subtitle">Vertauscht, welche Seite des Bildschirms vor- bzw. zurückblättert</string>
    <string name="settings_volume_keys_title">Lautstärketasten blättern Seiten um</string>
    <string name="settings_volume_keys_subtitle">Die Hardware-Lautstärketasten beim Lesen verwenden</string>
    <string name="settings_section_cloud_sync">Cloud-Synchronisierung</string>
    <string name="settings_section_cloud_sync_desc">Lesefortschritt und Gelesen-/Ungelesen-Status folgen dir geräteübergreifend über einen versteckten Ordner in deinem eigenen Google Drive — nichts anderes in deinem Drive wird berührt.</string>
    <string name="settings_sign_in_google">Mit Google anmelden</string>
    <string name="settings_signing_in">Anmeldung läuft…</string>
    <string name="settings_sync_progress_title">Lesefortschritt synchronisieren</string>
    <string name="settings_sync_progress_subtitle">Pausiert die Synchronisierung, ohne dich abzumelden</string>
    <string name="settings_sync_metadata_title">Korrigierte Metadaten synchronisieren</string>
    <string name="settings_sync_metadata_subtitle">Teilt Treffer von Metadaten korrigieren zwischen deinen Geräten, damit der Lesefortschritt korrekt übereinstimmt</string>
    <string name="settings_sync_background_title">Im Hintergrund synchronisieren</string>
    <string name="settings_sync_background_subtitle">Aus: synchronisiert nur, während die App geöffnet ist — keine geplante Akku-/Netzwerknutzung</string>
    <string name="settings_sync_last_synced">Zuletzt synchronisiert: %1$s</string>
    <string name="settings_sync_not_synced_yet">Noch nicht synchronisiert</string>
    <string name="settings_sign_out">Abmelden</string>
    <string name="settings_section_debug">Debug</string>
    <string name="settings_section_debug_desc">Die Rohdateien einsehen, löschen, exportieren oder importieren, die dieses Gerät über Google Drive synchronisiert.</string>
    <string name="settings_debug_view_progress">progress.json anzeigen</string>
    <string name="settings_debug_view_metadata_aliases">metadata_aliases.json anzeigen</string>
    <string name="settings_debug_clear_progress">progress.json löschen</string>
    <string name="settings_debug_clear_metadata_aliases">metadata_aliases.json löschen</string>
    <string name="settings_reset_library_title">Bibliothek zurücksetzen</string>
    <string name="settings_reset_library_desc">Vergisst die eingerichtete Quelle und löscht jede gescannte Serie, jedes Kapitel und jede Fortschrittszeile sowie alle zwischengespeicherten Cover-/Banner-Dateien. Kann nicht rückgängig gemacht werden.</string>
    <string name="settings_reset_confirm_title">Bibliothek zurücksetzen?</string>
    <string name="settings_reset_confirm_body">Dies löscht deine gesamte gescannte Bibliothek und alle zwischengespeicherten Cover-/Banner-Dateien und vergisst die eingerichtete Quelle (einschließlich eines gespeicherten SMB-Passworts). Deine Manga-Dateien selbst bleiben unangetastet. Dies kann nicht rückgängig gemacht werden.</string>
    <string name="settings_reset_confirm_action">Zurücksetzen</string>
    <string name="settings_debug_fetching">Wird von Drive geladen…</string>
    <string name="settings_debug_not_signed_in">(nicht angemeldet oder noch keine Datei vorhanden)</string>
    <string name="settings_debug_clear_confirm_title">%1$s löschen?</string>
    <string name="settings_debug_clear_confirm_body">Überschreibt die Kopie auf Drive mit einer leeren Datei. Die lokalen Daten dieses Geräts bleiben unberührt und werden bei der nächsten Synchronisierung wieder hochgeladen, aber andere Geräte verlieren ihren Beitrag zu dieser Datei, bis sie das nächste Mal synchronisieren.</string>
    <string name="settings_debug_clear_action">Löschen</string>
    <string name="settings_debug_export_progress">progress.json exportieren</string>
    <string name="settings_debug_export_metadata_aliases">metadata_aliases.json exportieren</string>
    <string name="settings_debug_import_progress">progress.json importieren</string>
    <string name="settings_debug_import_metadata_aliases">metadata_aliases.json importieren</string>
    <string name="settings_debug_import_confirm_title">%1$s importieren?</string>
    <string name="settings_debug_import_confirm_body">Überschreibt die Kopie auf Drive mit dem Inhalt der ausgewählten Datei. Andere Geräte gleichen sich bei ihrer nächsten Synchronisierung mit dieser Datei ab.</string>
    <string name="settings_debug_import_action">Importieren</string>
    <string name="settings_debug_import_failed_title">Import fehlgeschlagen</string>
